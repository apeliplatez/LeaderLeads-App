{
  "firestore": {
    "database": "firts",
    "rules": "firestore.rules"
  },
  "storage": {
    "bucket": "abstract-ring-466603-i7.firebasestorage.app",
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "abstract-ring-466603-i7",
    "public": "out",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/api/capi",
        "function": "sendMetaConversion"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(html|txt|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "functions": {
    "source": "functions",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  }
}